{
  "name": "project-channeltalk",
  "version": "0.1.0",
  "description": "Drop-in AI chatbot widget for Next.js — just add a knowledge.md file",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.mjs",
      "require": "./dist/react.cjs"
    },
    "./api": {
      "types": "./dist/api.d.ts",
      "import": "./dist/api.mjs",
      "require": "./dist/api.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "typesVersions": {
    "*": {
      "react": ["./dist/react.d.ts"],
      "api": ["./dist/api.d.ts"]
    }
  },
  "bin": {
    "project-channeltalk": "./dist/cli.mjs"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "dev:app": "next dev",
    "build:app": "next build",
    "start": "next start",
    "lint": "eslint",
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "next": ">=14.0.0",
    "ai": ">=5.0.0",
    "@ai-sdk/react": ">=3.0.0",
    "@ai-sdk/anthropic": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "@ai-sdk/anthropic": {
      "optional": true
    }
  },
  "dependencies": {
    "redis": "^4.7.0",
    "@base-ui/react": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "js-yaml": "^4.1.1",
    "lucide-react": "^0.577.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "^3.0.63",
    "@ai-sdk/react": "^3.0.136",
    "@tailwindcss/postcss": "^4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "ai": "^6.0.134",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.1.0",
    "tailwindcss": "^4",
    "tsup": "^8.5.1",
    "typescript": "^5"
  }
}
